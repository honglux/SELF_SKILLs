{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResultFile",
  "description": "磁盘文件 output/{session_id}/alerts.json 的结构",
  "type": "object",
  "required": ["session_id", "generated_at", "alerts"],
  "properties": {
    "session_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "alerts": {
      "type": "array",
      "items": { "$ref": "#/definitions/Alert" }
    }
  },
  "definitions": {
    "Alert": {
      "type": "object",
      "required": ["rule_id", "severity", "file", "line", "description", "evidence"],
      "properties": {
        "rule_id": { "type": "string", "const": "hardcoded-secret" },
        "severity": { "type": "string", "enum": ["high", "medium", "low", "info"] },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "description": { "type": "string" },
        "evidence": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
